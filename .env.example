# ============================================
# eCitizen Service Command Center - Environment
# ============================================

# Application
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
APP_NAME=eCitizen-SCC
# Citizen web portal URL (used in password-reset emails for citizens)
CLIENT_URL=http://localhost:3003
# Admin dashboard URL (used in password-reset emails for staff/agents)
ADMIN_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3003

# Database (PostgreSQL)
DATABASE_URL=postgresql://ecitizen:ecitizen_pass@localhost:5432/ecitizen_scc?schema=public
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=ecitizen
DB_PASSWORD=ecitizen_pass
DB_NAME=ecitizen_scc

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=24h

# Brevo (Email)
BREVO_API_KEY=your-brevo-api-key
BREVO_FROM_EMAIL=noreply@ecitizen.go.ke
BREVO_FROM_NAME=eCitizen Service Command Center

# Bonga SMS
BONGA_SMS_URL=https://api.bongasms.co.ke/v2/sms
BONGA_CLIENT_ID=your-bonga-client-id
BONGA_API_KEY=your-bonga-api-key
BONGA_API_SECRET=your-bonga-api-secret
BONGA_SERVICE_ID=your-bonga-service-id

# AWS S3 (Media Storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=af-south-1
S3_BUCKET=ecitizen-scc-media
CLOUDFRONT_DOMAIN=
CLOUDFRONT_ENABLED=false

# File Upload
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf,video/mp4,audio/mpeg

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# WebSocket
WS_PORT=4001

# Logging
LOG_LEVEL=debug

# ── NOTE: WebRTC / TURN credentials ──────────────────────────────────────────
# TURN server credentials (Xirsys) live in the FRONTEND envs, not here.
# Set these in webclient and admin deployment environments:
#   NEXT_PUBLIC_XIRSYS_USERNAME=nLwh8A66H...
#   NEXT_PUBLIC_XIRSYS_CREDENTIAL=f452fc82-3f3e...
# See webclient/.env.example and admin/.env.example for full values.

# ─── eCitizen OAuth (citizen single-sign-on) ──────────────────────────────────
# Register at https://forms.gle/gsgP1nQ9sQ5Vdrx48 (or whatever the current
# eCitizen OAuth registration form is). After approval you receive a
# client_id and a client_secret by email. Drop them here.
#
# IMPORTANT: client_secret is server-only. Never set NEXT_PUBLIC_* for these.
ECITIZEN_CLIENT_ID=
ECITIZEN_CLIENT_SECRET=
ECITIZEN_REDIRECT_URI=https://ecitizen.wasaahost.com/auth/ecitizen/callback
ECITIZEN_AUTHORIZE_URL=https://accounts.ecitizen.go.ke/oauth/authorize
ECITIZEN_TOKEN_URL=https://accounts.ecitizen.go.ke/oauth/access-token
ECITIZEN_USER_INFO_URL=https://accounts.ecitizen.go.ke/api/user-info
